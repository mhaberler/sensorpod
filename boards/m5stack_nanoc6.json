      "-DARDUINO_M5Stack_NanoC6",
      "-DARDUINO_USB_MODE=1"
    ],
    "f_cpu": "160000000L",
    "f_flash": "80000000L",
    "flash_mode": "qio",
    "hwids": [
      [
        "0x303A",
        "0x1001"
      ]
    ],
    "mcu": "esp32c6",
    "variant": "m5stack_nanoc6"
