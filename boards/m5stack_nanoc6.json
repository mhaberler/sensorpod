  "connectivity": [
    "wifi",
    "bluetooth",
    "zigbee",
    "thread"
  ],
  "debug": {
    "openocd_target": "esp32c6-builtin.cfg"
  },
  "frameworks": [
    "arduino",
    "espidf"
  ],
  "name": "M5Stack NanoC6",
  "upload": {
    "flash_size": "4MB",
    "maximum_ram_size": 524288,
    "maximum_size": 4194304,
    "require_upload_port": true,
    "speed": 460800,
    "protocol": "esptool"
  },
